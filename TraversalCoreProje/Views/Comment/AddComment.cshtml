@model int

@if(User.Identity.IsAuthenticated)
{
<div class="leave-comment-form mt-5" id="reply">
    <h4 class="side-title mb-2">Bir Yorum Bırakın</h4>
    <p class="mb-4">
        İşaretli alanları doldurunuz *
    </p>
    <form method="post" asp-action="AddComment" asp-controller="Comment">
        <input type="hidden" name="DestinationID" value="@Model" />
        <input type="hidden" name="AppUserID" value="@ViewBag.userId" />
        <div class="form-group">
            <textarea name="CommentContent" class="form-control" placeholder="Yorumunuz*" required=""
                      spellcheck="false"></textarea>
        </div>

        <div class="submit text-right">
            <button class="btn btn-style btn-primary">Yorum Yap </button>
        </div>
    </form>
</div>
}
else
{
    <div class="alert alert-warning" role="alert">
        Yorum yapabilmek için lütfen <a href="/Account/Login/">giriş yapınız</a> veya <a href="/Account/Register/">kayıt olunuz</a>.
    </div>
}
<script src="https://code.jquery.com/jquery-3.5.1.min.js" type="text/javascript"></script>